<h1>Your Cart</h1>

<% if @cart && @cart.order_items.any? %>
  <% @cart.order_items.each do |item| %>
    <div>
      <strong><%= item.product.title %></strong><br>
      Price: <%= item.price %><br>
      Quantity: <%= item.quantity %><br>
      Subtotal: <%= item.total_price %>
      <%= image_tag item.product.image.url, width: 80, height: 80, class: "rounded" %>
      <%= form_with url: order_item_path(item), method: :patch do %>
        <%= number_field_tag :quantity, item.quantity, min: 1 %>
        <%= submit_tag "Update" %>
      <% end %>
      
      <%= button_to "Delete", order_path, method: :delete, class:"btn btn-danger" %>
      

      <%= button_to "Remove From Cart",
      order_item_path(item),
      method: :delete,
      class: "btn btn-warning" %>


    </div>
    <hr>
  <% end %>


  <%= button_to "Checkout",
  order_checkout_path(@cart),
  method: :post,
  form: { "data-turbo" => false },
  class: "btn btn-success" %>
<% else %>
  <p>Your cart is empty</p>
<% end %>
